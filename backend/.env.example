# Alpaca (Stocks/ETFs) — get from https://alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# Binance (Crypto) — get from https://binance.com
# For testnet paper trading: https://testnet.binance.vision/
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

# Risk Limits
MAX_DAILY_LOSS_PCT=2.0
MAX_POSITION_SIZE_PCT=10.0
MAX_DRAWDOWN_HALT_PCT=15.0

# Logging
LOG_LEVEL=INFO
